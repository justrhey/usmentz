<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="500dp"
                android:centerX="0.5"
                android:centerY="0.3"
                android:startColor="#1A1A2E"
                android:endColor="#000000"/>
        </shape>
    </item>
    <!-- Subtle purple tint overlay -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#00000000"
                android:centerColor="#10090930"
                android:endColor="#15091A3F"/>
        </shape>
    </item>
    <!-- Bottom accent line -->
    <item android:top="498dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#9B5CFF"
                android:endColor="#2DD4C8"/>
            <size android:height="2dp"/>
        </shape>
    </item>
</layer-list>