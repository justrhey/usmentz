<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F7FF">

    <!-- Full-screen mascot/character area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomSection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Character/Mascot placeholder -->
        <View
            android:id="@+id/ivMascot"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:background="@drawable/bg_mascot_circle"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="usmentz"
            android:textColor="#9B5CFF"
            android:textSize="40sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_marginTop="32dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Track moments together"
            android:textColor="#9E9E9E"
            android:textSize="16sp"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

    <!-- Bottom section with CTA -->
    <LinearLayout
        android:id="@+id/bottomSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="24dp"
        android:paddingBottom="48dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Primary CTA -->
        <Button
            android:id="@+id/btnGetStarted"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Get Started"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#9B5CFF"
            app:cornerRadius="28dp"/>

        <!-- Secondary CTA -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="I already have an account"
            android:textColor="#9B5CFF"
            android:textSize="14sp"
            app:backgroundTint="#FFFFFF"
            app:cornerRadius="28dp"
            app:strokeColor="#9B5CFF"
            app:strokeWidth="1dp"
            android:layout_marginTop="12dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>