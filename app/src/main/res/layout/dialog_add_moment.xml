<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_top_round"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="20dp"
    android:paddingBottom="28dp">

    <!-- Handle bar -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_handle" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="New Moment"
        android:textColor="#212121"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="What was this place?"
        android:textColor="#9E9E9E"
        android:textSize="13sp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="16dp" />

    <!-- Name field — the ONE required field -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Place name"
        app:hintTextColor="#9E9E9E"
        app:boxStrokeColor="#9B5CFF"
        app:boxStrokeWidth="1dp"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_marginBottom="12dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#212121"
            android:textSize="16sp"
            android:inputType="textCapWords"
            android:singleLine="true"
            android:imeOptions="actionNext" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Feeling mood chips -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="How did it feel?"
        android:textColor="#9E9E9E"
        android:textSize="12sp"
        android:layout_marginBottom="6dp" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupFeeling"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        android:layout_marginBottom="12dp" />

    <!-- Category label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Category"
        android:textColor="#9E9E9E"
        android:textSize="12sp"
        android:layout_marginBottom="6dp" />

    <!-- Category chip selector -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipAddCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ New"
                android:textColor="#9B5CFF"
                android:textSize="13sp"
                app:chipBackgroundColor="@android:color/transparent"
                app:chipStrokeColor="#9B5CFF"
                app:chipStrokeWidth="1.5dp"
                app:chipCornerRadius="20dp"
                app:checkedIconVisible="false"
                android:layout_marginStart="4dp" />

        </LinearLayout>

    </HorizontalScrollView>

    <!-- More details toggle -->
    <TextView
        android:id="@+id/tvMoreDetails"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="+ Add more details"
        android:textColor="#9B5CFF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:padding="8dp"
        android:layout_marginBottom="8dp" />

    <!-- Hidden details section -->
    <LinearLayout
        android:id="@+id/detailsSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginBottom="12dp">

        <!-- Photo section -->
        <ImageView
            android:id="@+id/ivPhotoPreview"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_scrapbook_placeholder"
            android:visibility="gone"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <Button
                android:id="@+id/btnAddPhoto"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Add Photo"
                android:textSize="12sp"
                android:textColor="#9B5CFF"
                android:backgroundTint="#F3E8FF"
                app:cornerRadius="8dp"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnRemovePhoto"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Remove"
                android:textSize="12sp"
                android:textColor="#E91E63"
                android:backgroundTint="#FCE4EC"
                app:cornerRadius="8dp"
                android:visibility="gone"
                android:layout_marginStart="4dp" />

        </LinearLayout>

        <!-- Cost field -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Cost (optional)"
            app:hintTextColor="#9E9E9E"
            app:boxStrokeColor="#9B5CFF"
            app:boxStrokeWidth="1dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="10dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCost"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#212121"
                android:textSize="14sp"
                android:inputType="numberDecimal"
                android:singleLine="true" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Review notes -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="What stood out? (private journal)"
            app:hintTextColor="#9E9E9E"
            app:boxStrokeColor="#9B5CFF"
            app:boxStrokeWidth="1dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="10dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etReviewNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#212121"
                android:textSize="14sp"
                android:inputType="textMultiLine"
                android:minLines="2"
                android:maxLines="4" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Do again toggle -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchDoAgain"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Would you do this again?"
            android:textColor="#212121"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="Cancel"
            android:textColor="#757575"
            android:textSize="14sp"
            android:backgroundTint="#F5F5F5"
            android:layout_marginEnd="8dp"
            app:cornerRadius="12dp" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="Add"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:backgroundTint="#9B5CFF"
            app:cornerRadius="12dp" />

    </LinearLayout>

</LinearLayout>
