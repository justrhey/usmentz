<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_top_round"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="20dp"
    android:paddingBottom="24dp">

    <!-- Handle bar -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_handle" />

    <!-- Progress dots -->
    <LinearLayout
        android:id="@+id/progressDots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">
        <View android:id="@+id/dot1" android:layout_width="24dp" android:layout_height="4dp" android:background="#9B5CFF" android:layout_marginEnd="4dp"/>
        <View android:id="@+id/dot2" android:layout_width="8dp" android:layout_height="8dp" android:background="#E8D5F5" android:layout_marginEnd="4dp" android:layout_gravity="center_vertical"/>
        <View android:id="@+id/dot3" android:layout_width="8dp" android:layout_height="8dp" android:background="#E8D5F5" android:layout_gravity="center_vertical"/>
    </LinearLayout>

    <ViewFlipper
        android:id="@+id/viewFlipper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inAnimation="@android:anim/fade_in"
        android:outAnimation="@android:anim/fade_out">

        <!-- STEP 1: Place -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Where were you?"
                android:textColor="#2D2640"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Name the place or moment"
                android:textColor="#8B7FA8"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. Sunset dinner, Beach walk..."
                app:boxStrokeColor="#9B5CFF"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="24dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords"
                    android:singleLine="true" />

            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/btnNext1"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Next"
                android:textColor="#FFFFFF"
                android:backgroundTint="#9B5CFF"
                app:cornerRadius="12dp" />

        </LinearLayout>

        <!-- STEP 2: Vibe -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="How did it feel?"
                android:textColor="#2D2640"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap to select the vibe"
                android:textColor="#8B7FA8"
                android:textSize="14sp"
                android:layout_marginBottom="20dp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupFeeling"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnBack2"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:text="Back"
                    android:textColor="#9B5CFF"
                    android:backgroundTint="#F3E8FF"
                    app:cornerRadius="12dp"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btnNext2"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:text="Next"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#9B5CFF"
                    app:cornerRadius="12dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- STEP 3: Details (Optional) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Anything else?"
                android:textColor="#2D2640"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add photo, cost, or notes (optional)"
                android:textColor="#8B7FA8"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <!-- Category Chips -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Category"
                android:textColor="#2D2640"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="16dp">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true" />

            </HorizontalScrollView>

            <!-- Photo Preview -->
            <ImageView
                android:id="@+id/ivPhotoPreview"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_scrapbook_placeholder"
                android:visibility="gone"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <Button
                    android:id="@+id/btnAddPhoto"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="Add Photo"
                    android:textSize="12sp"
                    android:textColor="#9B5CFF"
                    android:backgroundTint="#F3E8FF"
                    app:cornerRadius="8dp" />

                <Button
                    android:id="@+id/btnRemovePhoto"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Remove"
                    android:textSize="12sp"
                    android:textColor="#E91E63"
                    android:backgroundTint="#FCE4EC"
                    app:cornerRadius="8dp"
                    android:visibility="gone"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- Cost -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Cost (optional)"
                app:boxStrokeColor="#9B5CFF"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="10dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCost"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:singleLine="true" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Notes -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="A quick note..."
                app:boxStrokeColor="#9B5CFF"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="10dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etReviewNotes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:minLines="2" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Do Again -->
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchDoAgain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Would you do this again?"
                android:textColor="#2D2640"
                android:layout_marginBottom="20dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnBack3"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:text="Back"
                    android:textColor="#9B5CFF"
                    android:backgroundTint="#F3E8FF"
                    app:cornerRadius="12dp"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btnSave"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:text="Save Memory"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#9B5CFF"
                    app:cornerRadius="12dp" />

            </LinearLayout>

        </LinearLayout>

    </ViewFlipper>

</LinearLayout>
