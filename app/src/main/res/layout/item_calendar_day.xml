<?xml version="1.0" encoding="utf-8"?>
<!-- Calendar grid cell - supports standard, circular, and capsule nodes -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="2dp">

    <!-- Standard numeric node -->
    <TextView
        android:id="@+id/tvDay"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:gravity="center"
        android:text="15"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium" />

    <!-- Circular container (1:1 aspect ratio) -->
    <View
        android:id="@+id/viewTodayCircle"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_circle_today"
        android:visibility="gone" />

    <!-- Selected circular container -->
    <View
        android:id="@+id/viewSelectedCircle"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_circle_selected"
        android:visibility="gone" />

    <!-- Capsule container (spans multiple columns) -->
    <LinearLayout
        android:id="@+id/capsuleContainer"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/bg_capsule_purple"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvCapsuleDay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="15"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/tvCapsuleLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Date"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:layout_marginStart="4dp"
            android:alpha="0.9" />

    </LinearLayout>

</FrameLayout>
