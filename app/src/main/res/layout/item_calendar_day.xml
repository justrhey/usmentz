<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="?attr/selectableItemBackground">

        <!-- Day number -->
        <TextView
            android:id="@+id/tvDay"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="24"
            android:textColor="#212121"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <!-- Event dot indicator -->
        <View
            android:id="@+id/viewEventDot"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/bg_timeline_dot"
            android:visibility="gone"/>

    </LinearLayout>

    <!-- Today circle overlay (hidden by default) -->
    <View
        android:id="@+id/viewTodayCircle"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_day_today"
        android:visibility="gone"/>

    <!-- Selected circle overlay (hidden by default) -->
    <View
        android:id="@+id/viewSelectedCircle"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_day_selected"
        android:visibility="gone"/>

</FrameLayout>