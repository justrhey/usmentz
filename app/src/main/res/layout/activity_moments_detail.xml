<?xml version="1.0" encoding="utf-8"?>

<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nestedScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0C0C1E"
    android:fillViewport="true">

<LinearLayout
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:orientation="vertical"
android:padding="16dp"
android:paddingBottom="88dp">

<!-- ── Hero name + date card ── -->
<androidx.cardview.widget.CardView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#13132A"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp">

        <!-- Moment name -->
        <TextView
            android:id="@+id/tvMomentName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Moment Name"
            android:textColor="#F0E6FF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:letterSpacing="-0.01"
            android:layout_marginBottom="8dp" />

        <!-- Date row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅"
                android:textSize="14sp"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date"
                android:textColor="#7A6A9A"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>

<!-- ── Location card ── -->
<androidx.cardview.widget.CardView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#13132A"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📍  LOCATION"
            android:textColor="#9B5CFF"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Address"
            android:textColor="#F0E6FF"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.4" />

    </LinearLayout>
</androidx.cardview.widget.CardView>

<!-- ── Description card ── -->
<androidx.cardview.widget.CardView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#13132A"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📝  DESCRIPTION"
            android:textColor="#9B5CFF"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No description"
            android:textColor="#F0E6FF"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.5" />

    </LinearLayout>
</androidx.cardview.widget.CardView>

<!-- ── Rating card ── -->
<androidx.cardview.widget.CardView
    android:id="@+id/ratingSection"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#13132A"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⭐  RATING"
            android:textColor="#9B5CFF"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <RatingBar
            android:id="@+id/ratingBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:stepSize="0.5"
            android:rating="0"
            android:isIndicator="true"
            android:progressTint="#9B5CFF"
            android:secondaryProgressTint="#2A1A50" />

        <TextView
            android:id="@+id/tvRatingLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rating"
            android:textColor="#7A6A9A"
            android:textSize="12sp"
            android:layout_marginTop="4dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>

<!-- ── Photo card ── -->
<androidx.cardview.widget.CardView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#13132A"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📷  PHOTO"
            android:textColor="#9B5CFF"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="14dp" />

        <!-- Photo frame -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardPhoto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            app:cardBackgroundColor="#1C1C38"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="#9B5CFF"
            app:strokeWidth="2dp">
            <ImageView
                android:id="@+id/ivPhoto"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:scaleType="centerCrop" />
        </androidx.cardview.widget.CardView>

        <!-- No photo placeholder -->
        <LinearLayout
            android:id="@+id/tvNoPhoto"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#1C1C38"
            android:layout_marginBottom="12dp"
            android:visibility="visible">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📷"
                android:textSize="28sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No photo added"
                android:textColor="#3D3660"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnSelectPhoto"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Change Photo"
            android:textColor="#2DD4C8"
            android:textSize="14sp"
            android:backgroundTint="#0D3B38"
            android:stateListAnimator="@null" />

    </LinearLayout>
</androidx.cardview.widget.CardView>

<!-- ── Review text card ── -->
<androidx.cardview.widget.CardView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#13132A"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📝  YOUR REVIEW"
            android:textColor="#9B5CFF"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvReview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No review yet"
            android:textColor="#F0E6FF"
            android:textSize="14sp"
            android:background="#1C1C38"
            android:padding="16dp"
            android:gravity="top|start"
            android:minLines="3"
            android:visibility="gone" />

        <EditText
            android:id="@+id/etReview"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:hint="Write your thoughts about this moment…"
            android:textColor="#F0E6FF"
            android:textColorHint="#3D3660"
            android:textSize="14sp"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:gravity="top|start"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="5"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnSaveReview"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Save Review"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:backgroundTint="#9B5CFF"
            android:stateListAnimator="@null"
            android:layout_marginTop="14dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnEditReview"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Edit Review"
            android:textColor="#2DD4C8"
            android:textSize="14sp"
            android:textStyle="bold"
            android:backgroundTint="#0D3B38"
            android:stateListAnimator="@null"
            android:layout_marginTop="14dp"
            android:visibility="gone" />

    </LinearLayout>
</androidx.cardview.widget.CardView>

<!-- ── Money Manager Section ── -->
<androidx.cardview.widget.CardView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#13132A"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💰  EXPENSES"
            android:textColor="#FFB020"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Total spent -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1C1C38"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Total spent:"
                android:textColor="#7A6A9A"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvTotalSpent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱0.00"
                android:textColor="#FFB020"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Add expense inline -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ADD EXPENSE"
            android:textColor="#5A4E7A"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etExpenseDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Description (e.g., Dinner)"
            android:textColor="#F0E6FF"
            android:textColorHint="#3D3660"
            android:background="@drawable/bg_input"
            android:padding="12dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etExpenseAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Amount (₱)"
            android:inputType="numberDecimal"
            android:textColor="#F0E6FF"
            android:textColorHint="#3D3660"
            android:background="@drawable/bg_input"
            android:padding="12dp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnAddExpenseInline"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="+ Add Expense"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:backgroundTint="#FFB020"
            android:stateListAnimator="@null"
            android:layout_marginBottom="16dp" />

        <!-- Expenses list -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="EXPENSES LIST"
            android:textColor="#5A4E7A"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="8dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/expensesRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />

        <TextView
            android:id="@+id/tvEmptyExpenses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No expenses added yet"
            android:textColor="#3D3660"
            android:textSize="13sp"
            android:gravity="center"
            android:padding="16dp"
            android:visibility="visible" />

    </LinearLayout>
</androidx.cardview.widget.CardView>

<!-- ── Action buttons ── -->
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center"
    android:layout_marginTop="8dp">

    <Button
        android:id="@+id/btnEdit"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:layout_marginEnd="8dp"
        android:text="Edit"
        android:textColor="#FFFFFF"
        android:backgroundTint="#9B5CFF"
        android:stateListAnimator="@null" />

    <Button
        android:id="@+id/btnDelete"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:text="Delete"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FF4444"
        android:stateListAnimator="@null" />

</LinearLayout>

</LinearLayout>
    </androidx.core.widget.NestedScrollView>