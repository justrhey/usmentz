<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Minimalist Toolbar - No back button -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FFFFFF"
        app:titleTextColor="#212121" />

    <!-- Segmented Control Tab Bar - Horizontal Content Switcher -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_segmented_control"
        android:padding="4dp">

        <!-- Details Tab -->
        <LinearLayout
            android:id="@+id/tabDetails"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_tab_active">

            <TextView
                android:id="@+id/tvTabDetails"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Details"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#212121"/>
        </LinearLayout>

        <!-- Expenses Tab -->
        <LinearLayout
            android:id="@+id/tabExpenses"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_tab_inactive">

            <TextView
                android:id="@+id/tvTabExpenses"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Expenses"
                android:textSize="14sp"
                android:textColor="#9E9E9E"/>
        </LinearLayout>

        <!-- Review Tab -->
        <LinearLayout
            android:id="@+id/tabReview"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_tab_inactive">

            <TextView
                android:id="@+id/tvTabReview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Review"
                android:textSize="14sp"
                android:textColor="#9E9E9E"/>
        </LinearLayout>

    </LinearLayout>

    <!-- ViewPager2 for fragments -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>