<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0C0C1E">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#0C0C1E"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="#9B5CFF"
        app:titleTextColor="#F0E6FF" />

    <!-- Tab Layout -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#0C0C1E"
        app:tabTextColor="#3D3660"
        app:tabSelectedTextColor="#9B5CFF"
        app:tabIndicatorColor="#9B5CFF"
        app:tabIndicatorHeight="3dp" />

    <!-- ViewPager2 for fragments -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Edit FAB (only visible on first tab) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabEdit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@drawable/ic_edit"
        android:contentDescription="Edit"
        app:backgroundTint="#9B5CFF"
        app:tint="#FFFFFF"
        app:fabSize="normal"
        android:visibility="gone" />

</LinearLayout>