<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal">

    <!-- Timeline Column (Left) -->
    <LinearLayout
        android:layout_width="40dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Top Line -->
        <View
            android:id="@+id/topLine"
            android:layout_width="2dp"
            android:layout_height="20dp"
            android:background="@color/black_border"/>

        <!-- Timeline Dot -->
        <View
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/bg_timeline_dot"/>

        <!-- Bottom Line (expands) -->
        <View
            android:id="@+id/bottomLine"
            android:layout_width="2dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:minHeight="20dp"
            android:background="@color/black_border"/>

    </LinearLayout>

    <!-- Card Content (Right) -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/black_card"
        app:strokeColor="@color/purple_border"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header: Profile Icon, Name, Date -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp">

                <!-- Profile Circle -->
                <ImageView
                    android:id="@+id/ivProfile"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_categories"
                    android:background="@drawable/bg_circle_purple_light"
                    android:padding="8dp"
                    app:tint="@color/purple_primary"/>

                <!-- Name and Date Column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:id="@+id/tvMomentName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Moment Name"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="May 9"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:layout_marginTop="1dp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Rating Stars Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingBottom="4dp">

                <RatingBar
                    android:id="@+id/ratingBar"
                    android:layout_width="wrap_content"
                    android:layout_height="18dp"
                    android:numStars="5"
                    android:rating="0"
                    android:stepSize="0.5"
                    android:progressTint="@color/amber_accent"
                    android:secondaryProgressTint="@color/black_border"
                    android:isIndicator="true"
                    style="@style/Widget.AppCompat.RatingBar.Small"/>

                <TextView
                    android:id="@+id/tvRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.0"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginStart="6dp"/>

            </LinearLayout>

            <!-- Review Text -->
            <TextView
                android:id="@+id/tvReviewText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Review text here..."
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.3"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingBottom="10dp"/>

            <!-- Photo (if exists) - Full width -->
            <ImageView
                android:id="@+id/ivPhoto"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:background="@color/black_elevated"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>