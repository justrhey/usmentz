<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/capsuleNavbar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="20dp"
    android:layout_marginEnd="20dp"
    android:layout_marginBottom="28dp"
    app:cardCornerRadius="40dp"
    app:cardElevation="16dp"
    app:cardBackgroundColor="@color/black_elevated"
    app:strokeWidth="1dp"
    app:strokeColor="@color/black_border">

    <LinearLayout
        android:id="@+id/navContainer"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">

        <!-- Home (Active by default) -->
        <LinearLayout
            android:id="@+id/navItemHome"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="2.5"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_nav_active_pill"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/navIconHome"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/navLabelHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:layout_marginStart="10dp"
                android:visibility="visible"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Categories (Inactive) -->
        <LinearLayout
            android:id="@+id/navItemCategories"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/navIconCategories"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_category"
                app:tint="@color/text_hint" />

            <TextView
                android:id="@+id/navLabelCategories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Categories"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:layout_marginStart="10dp"
                android:visibility="gone"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Calendar (Inactive) -->
        <LinearLayout
            android:id="@+id/navItemCalendar"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/navIconCalendar"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_calendar"
                app:tint="@color/text_hint" />

            <TextView
                android:id="@+id/navLabelCalendar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Calendar"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:layout_marginStart="10dp"
                android:visibility="gone"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Favorites (Inactive) -->
        <LinearLayout
            android:id="@+id/navItemFavorites"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/navIconFavorites"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_heart_filled"
                app:tint="@color/text_hint" />

            <TextView
                android:id="@+id/navLabelFavorites"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Favorites"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:layout_marginStart="10dp"
                android:visibility="gone"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Settings (Inactive) -->
        <LinearLayout
            android:id="@+id/navItemSettings"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/navIconSettings"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_settings"
                app:tint="@color/text_hint" />

            <TextView
                android:id="@+id/navLabelSettings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:layout_marginStart="10dp"
                android:visibility="gone"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
