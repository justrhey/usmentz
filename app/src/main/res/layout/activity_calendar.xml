<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F7FF"
    android:fitsSystemWindows="true">

    <!-- ═══════════════════════════════════════════ -->
    <!-- MAIN CONTENT                                -->
    <!-- ═══════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ────────────────────────────────────────
             1. TOP STATUS & HEADER BAR
        ──────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/topHeader"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="#FFFFFF"
            android:elevation="2dp">

            <!-- Left: Chevron (back) -->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#2D2640"
                android:contentDescription="Back"
                android:padding="6dp" />

            <!-- Center: Bold uppercase month/year -->
            <TextView
                android:id="@+id/tvMonthYear"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="JULY 2026"
                android:textColor="#2D2640"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:gravity="center"
                android:fontFamily="sans-serif-medium"
                android:layout_marginStart="8dp" />

            <!-- Right: Sidebar icon -->
            <ImageButton
                android:id="@+id/btnOpenDrawer"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_menu"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#8B7FA8"
                android:contentDescription="Menu"
                android:padding="6dp" />

        </LinearLayout>

        <!-- ────────────────────────────────────────
             2. CALENDAR GRID SECTION (Upper Half)
        ──────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#FFFFFF">

            <!-- Day-of-week label row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="12dp"
                android:paddingBottom="8dp">

                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="S" android:textColor="#BDBDBD" android:textSize="11sp" android:gravity="center" android:fontFamily="sans-serif-medium"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="M" android:textColor="#BDBDBD" android:textSize="11sp" android:gravity="center" android:fontFamily="sans-serif-medium"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="T" android:textColor="#BDBDBD" android:textSize="11sp" android:gravity="center" android:fontFamily="sans-serif-medium"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="W" android:textColor="#BDBDBD" android:textSize="11sp" android:gravity="center" android:fontFamily="sans-serif-medium"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="T" android:textColor="#BDBDBD" android:textSize="11sp" android:gravity="center" android:fontFamily="sans-serif-medium"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="F" android:textColor="#BDBDBD" android:textSize="11sp" android:gravity="center" android:fontFamily="sans-serif-medium"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="S" android:textColor="#BDBDBD" android:textSize="11sp" android:gravity="center" android:fontFamily="sans-serif-medium"/>

            </LinearLayout>

            <!-- Prev/Today/Next row -->
            <LinearLayout
                android:id="@+id/navRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp">

                <ImageButton
                    android:id="@+id/btnPrevMonth"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_back"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="#8B7FA8"
                    android:contentDescription="Previous month"
                    android:padding="4dp" />

                <Button
                    android:id="@+id/btnToday"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:text="Today"
                    android:textColor="#9B5CFF"
                    android:textSize="11sp"
                    android:textAllCaps="false"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="@drawable/bg_pill_purple"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp" />

                <ImageButton
                    android:id="@+id/btnNextMonth"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_back"
                    android:rotation="180"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="#8B7FA8"
                    android:contentDescription="Next month"
                    android:padding="4dp" />

            </LinearLayout>

            <!-- Calendar grid (7x5 numeric matrix) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCalendar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:overScrollMode="never" />

        </LinearLayout>

        <!-- ────────────────────────────────────────
             3. LIST ITEM SECTION (Lower Half)
        ──────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/listSection"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:background="#F8F7FF">

            <TextView
                android:id="@+id/tvListHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Moments"
                android:textColor="#2D2640"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMoments"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingBottom="100dp" />

            <TextView
                android:id="@+id/tvNoMoments"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="No moments this month"
                android:textColor="#BDBDBD"
                android:textSize="13sp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- ────────────────────────────────────────
             4. BOTTOM GLOBAL NAVIGATION BAR
        ──────────────────────────────────────── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:elevation="8dp">

            <!-- Nav bar container -->
            <LinearLayout
                android:id="@+id/navbarContainer"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <!-- Slot 1: Home -->
                <LinearLayout
                    android:id="@+id/navItemHome"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_home"
                        app:tint="#8B7FA8" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Home"
                        android:textColor="#8B7FA8"
                        android:textSize="10sp"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <!-- Slot 2: Categories -->
                <LinearLayout
                    android:id="@+id/navItemCategories"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_category"
                        app:tint="#8B7FA8" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Categories"
                        android:textColor="#8B7FA8"
                        android:textSize="10sp"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <!-- Center spacer for FAB -->
                <View
                    android:layout_width="48dp"
                    android:layout_height="0dp" />

                <!-- Slot 3: Calendar (active) -->
                <LinearLayout
                    android:id="@+id/navItemCalendar"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_calendar"
                        app:tint="#9B5CFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Calendar"
                        android:textColor="#9B5CFF"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <!-- Slot 4: Favorites -->
                <LinearLayout
                    android:id="@+id/navItemFavorites"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_heart"
                        app:tint="#8B7FA8" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Favorites"
                        android:textColor="#8B7FA8"
                        android:textSize="10sp"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Central Floating Action Node - breaks out of nav bar -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabAdd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="-28dp"
                android:src="@drawable/ic_add"
                android:contentDescription="Add"
                app:backgroundTint="#9B5CFF"
                app:tint="#FFFFFF"
                app:fabSize="normal"
                app:elevation="12dp" />

        </FrameLayout>

    </LinearLayout>

    <!-- ═══════════════════════════════════════════ -->
    <!-- SIDEBAR DRAWER                               -->
    <!-- ═══════════════════════════════════════════ -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navDrawer"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        app:headerLayout="@layout/drawer_calendar_header"
        app:menu="@menu/menu_calendar_drawer"/>

</androidx.drawerlayout.widget.DrawerLayout>
