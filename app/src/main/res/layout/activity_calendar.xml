<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F7FF">

    <!-- ═══════════════════════════════════════════ -->
    <!-- 1. TOP HEADER BAR (56dp)                   -->
    <!-- ═══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/topNavBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:background="#FFFFFF"
        android:elevation="2dp">

        <!-- Left: Month + Year bold heading -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom">

            <TextView
                android:id="@+id/tvMonth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="July"
                android:textColor="#1A1A1A"
                android:textSize="22sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvYear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2026"
                android:textColor="#BDBDBD"
                android:textSize="14sp"
                android:layout_marginStart="6dp"
                android:layout_marginBottom="2dp"/>

        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- Right: Utility icons -->
        <ImageButton
            android:id="@+id/btnFilter"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_filter"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="6dp"
            app:tint="#9E9E9E"
            android:contentDescription="Filter"/>

        <ImageButton
            android:id="@+id/btnSort"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_sort"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="6dp"
            app:tint="#9E9E9E"
            android:contentDescription="Sort"
            android:layout_marginStart="8dp"/>

        <ImageButton
            android:id="@+id/btnAnalytics"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_analytics"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="6dp"
            app:tint="#9E9E9E"
            android:contentDescription="Analytics"
            android:layout_marginStart="8dp"/>

    </LinearLayout>

    <!-- ═══════════════════════════════════════════ -->
    <!-- 2. SEGMENTED CONTROL ROW (48dp)            -->
    <!-- ═══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/secondaryBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:background="#FFFFFF">

        <!-- Segmented Control: List | Grid | Board | Cal -->
        <LinearLayout
            android:id="@+id/segmentedControl"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_segmented"
            android:padding="2dp">

            <TextView
                android:id="@+id/segList"
                android:layout_width="44dp"
                android:layout_height="26dp"
                android:text="List"
                android:textSize="11sp"
                android:textColor="#9E9E9E"
                android:gravity="center"
                android:background="@drawable/bg_segment_item"/>

            <View
                android:layout_width="1dp"
                android:layout_height="14dp"
                android:layout_gravity="center"
                android:background="#E0E0E0"/>

            <TextView
                android:id="@+id/segGrid"
                android:layout_width="44dp"
                android:layout_height="26dp"
                android:text="Grid"
                android:textSize="11sp"
                android:textColor="#9E9E9E"
                android:gravity="center"
                android:background="@drawable/bg_segment_item"/>

            <View
                android:layout_width="1dp"
                android:layout_height="14dp"
                android:layout_gravity="center"
                android:background="#E0E0E0"/>

            <TextView
                android:id="@+id/segBoard"
                android:layout_width="48dp"
                android:layout_height="26dp"
                android:text="Board"
                android:textSize="11sp"
                android:textColor="#9E9E9E"
                android:gravity="center"
                android:background="@drawable/bg_segment_item"/>

            <View
                android:layout_width="1dp"
                android:layout_height="14dp"
                android:layout_gravity="center"
                android:background="#E0E0E0"/>

            <TextView
                android:id="@+id/segCalendar"
                android:layout_width="46dp"
                android:layout_height="26dp"
                android:text="Cal"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:background="@drawable/bg_segment_item_active"/>

        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- Right: Add pill button -->
        <LinearLayout
            android:id="@+id/btnAdd"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp"
            android:background="@drawable/bg_pill_add"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_add"
                app:tint="#FFFFFF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="6dp"/>

        </LinearLayout>

    </LinearLayout>

    <!-- ═══════════════════════════════════════════ -->
    <!-- 3. TODAY + MONTH NAV BAR (44dp)            -->
    <!-- ═══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/navBar"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="104dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:background="#FFFFFF">

        <!-- Today pill -->
        <Button
            android:id="@+id/btnToday"
            android:layout_width="wrap_content"
            android:layout_height="26dp"
            android:text="Today"
            android:textColor="#9B5CFF"
            android:textSize="11sp"
            android:textAllCaps="false"
            android:paddingHorizontal="14dp"
            android:background="@drawable/bg_pill_purple"/>

        <View
            android:layout_width="20dp"
            android:layout_height="0dp"/>

        <!-- Prev arrow -->
        <ImageButton
            android:id="@+id/btnPrevMonth"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#9E9E9E"
            android:contentDescription="Previous month"
            android:padding="6dp"/>

        <!-- Nav label (Month Year) -->
        <TextView
            android:id="@+id/tvNavLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="July 2026"
            android:textColor="#1A1A1A"
            android:textSize="13sp"
            android:layout_marginHorizontal="10dp"/>

        <!-- Next arrow -->
        <ImageButton
            android:id="@+id/btnNextMonth"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_back"
            android:rotation="180"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#9E9E9E"
            android:contentDescription="Next month"
            android:padding="6dp"/>

    </LinearLayout>

    <!-- Divider line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="148dp"
        android:background="#F0F0F0"/>

    <!-- ═══════════════════════════════════════════ -->
    <!-- 4. MAIN GRID (scrollable)                  -->
    <!-- ═══════════════════════════════════════════ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="149dp"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="16dp"
            android:paddingBottom="120dp">

            <!-- Grid Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#EEEEEE"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="16dp"
                    android:paddingHorizontal="12dp">

                    <!-- Day Name Headers -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="S"
                            android:textColor="#BDBDBD"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:fontFamily="sans-serif-medium"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="M"
                            android:textColor="#BDBDBD"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:fontFamily="sans-serif-medium"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="T"
                            android:textColor="#BDBDBD"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:fontFamily="sans-serif-medium"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="W"
                            android:textColor="#BDBDBD"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:fontFamily="sans-serif-medium"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="T"
                            android:textColor="#BDBDBD"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:fontFamily="sans-serif-medium"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="F"
                            android:textColor="#BDBDBD"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:fontFamily="sans-serif-medium"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="S"
                            android:textColor="#BDBDBD"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:fontFamily="sans-serif-medium"/>

                    </LinearLayout>

                    <!-- Calendar Grid -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvCalendar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:overScrollMode="never"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="16dp"/>

            <!-- Day Events Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDayEvents"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:visibility="gone"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:id="@+id/tvSelectedDate"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="July 15, 2026"
                            android:textColor="#1A1A1A"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvDayTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2 moments"
                            android:textColor="#9B5CFF"
                            android:textSize="12sp"/>

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0F0F0"
                        android:layout_marginBottom="12dp"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvDayMoments"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"/>

                    <TextView
                        android:id="@+id/tvNoMomentsDay"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="No moments on this day"
                        android:textColor="#BDBDBD"
                        android:textSize="14sp"
                        android:visibility="gone"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

    <!-- ═══════════════════════════════════════════ -->
    <!-- 5. BOTTOM: FAB + NAVBAR                   -->
    <!-- ═══════════════════════════════════════════ -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        android:src="@drawable/ic_add"
        android:contentDescription="Add"
        app:backgroundTint="#9B5CFF"
        app:tint="#FFFFFF"
        app:fabSize="normal"
        app:elevation="12dp"/>

    <!-- Floating Pill Navbar -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/floatingNavbarContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="20dp"
        app:cardBackgroundColor="#F2FFFFFF"
        app:cardCornerRadius="32dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <LinearLayout
                android:id="@+id/navHome"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_home" app:tint="#9E9E9E"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Home" android:textSize="9sp" android:textColor="#9E9E9E" android:layout_marginTop="3dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navCategories"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_category" app:tint="#9E9E9E"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Categories" android:textSize="9sp" android:textColor="#9E9E9E" android:layout_marginTop="3dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navReviews"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_star" app:tint="#9E9E9E"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Reviews" android:textSize="9sp" android:textColor="#9E9E9E" android:layout_marginTop="3dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navCalendar"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_calendar" app:tint="#9B5CFF"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Calendar" android:textSize="9sp" android:textColor="#9B5CFF" android:layout_marginTop="3dp"/>
            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Hidden toolbar for compatibility -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>