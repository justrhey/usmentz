<!-- Calendar card - WITH CUSTOM MONTH GRAPHIC CONTAINER -->
<androidx.cardview.widget.CardView android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_margin="16dp"
    app:cardBackgroundColor="#13132A"
    app:cardCornerRadius="28dp"
    app:cardElevation="0dp"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- CUSTOM MONTH GRAPHIC CONTAINER - REPLACES TEXT -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="100dp"
            app:cardBackgroundColor="#1C1C38"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp">

                <!-- Left side: Month graphic (you'll replace with custom image) -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="MARCH"
                    android:textColor="#9B5CFF"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="-0.02"
                    android:alpha="0.9" />

                <!-- Month navigation buttons -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/btnPrevMonth"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_back"
                        android:background="?selectableItemBackgroundBorderless"
                        android:backgroundTint="#2A2A4A"
                        android:contentDescription="Previous month"
                        android:padding="12dp" />

                    <ImageButton
                        android:id="@+id/btnNextMonth"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_add"
                        android:background="?selectableItemBackgroundBorderless"
                        android:backgroundTint="#2A2A4A"
                        android:contentDescription="Next month"
                        android:padding="12dp"
                        android:layout_marginStart="8dp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- REMOVED: Month text row completely -->
        <!-- REMOVED: Year row completely -->
        <!-- REMOVED: Today button -->

        <!-- Day headers - KEEP THESE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="S"
                android:textColor="#3D3660"
                android:textSize="13sp"
                android:textStyle="bold" />
            <!-- ... other day headers ... -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="S"
                android:textColor="#3D3660"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Calendar grid -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCalendar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />

        <!-- Legend (optional) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="16dp">
            <!-- ... legend items ... -->
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>