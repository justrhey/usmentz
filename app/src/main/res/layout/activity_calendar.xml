<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Clean Header - Month & Year same baseline -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="bottom"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="8dp">

        <!-- Month - Large -->
        <TextView
            android:id="@+id/tvMonth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="July"
            android:textColor="#212121"
            android:textSize="32sp"
            android:textStyle="bold" />

        <!-- Year - Muted tone -->
        <TextView
            android:id="@+id/tvYear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2026"
            android:textColor="#BDBDBD"
            android:textSize="16sp"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="4dp" />

    </LinearLayout>

    <!-- Year Options - Inline row (slides open) -->
    <LinearLayout
        android:id="@+id/yearOptionsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="8dp"
        android:visibility="gone">

        <TextView android:layout_width="wrap_content" android:layout_height="36dp" android:text="2024" android:textColor="#757575" android:textSize="14sp" android:gravity="center" android:paddingHorizontal="12dp" android:background="?attr/selectableItemBackgroundBorderless" />
        <TextView android:layout_width="wrap_content" android:layout_height="36dp" android:text="2025" android:textColor="#757575" android:textSize="14sp" android:gravity="center" android:paddingHorizontal="12dp" android:background="?attr/selectableItemBackgroundBorderless" />
        <TextView android:layout_width="wrap_content" android:layout_height="36dp" android:text="2026" android:textColor="#9B5CFF" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:paddingHorizontal="12dp" android:background="@drawable/bg_year_selected" />
        <TextView android:layout_width="wrap_content" android:layout_height="36dp" android:text="2027" android:textColor="#757575" android:textSize="14sp" android:gravity="center" android:paddingHorizontal="12dp" android:background="?attr/selectableItemBackgroundBorderless" />
    </LinearLayout>

    <!-- Week Navigation - Bare icons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:paddingVertical="12dp">

        <ImageButton
            android:id="@+id/btnPrevWeek"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:rotation="180"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#757575" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="This Week"
            android:textColor="#9E9E9E"
            android:textSize="12sp"
            android:gravity="center" />

        <ImageButton
            android:id="@+id/btnNextWeek"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#757575" />
    </LinearLayout>

    <!-- Day Columns -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp">

        <!-- MON -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MON" android:textColor="#9E9E9E" android:textSize="10sp" />
            <TextView android:id="@+id/tvDay13" android:layout_width="44dp" android:layout_height="44dp" android:gravity="center" android:text="13" android:textColor="#212121" android:textSize="18sp" android:textStyle="bold" android:background="@drawable/bg_day_inactive" />
        </LinearLayout>

        <!-- TUE -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TUE" android:textColor="#9E9E9E" android:textSize="10sp" />
            <TextView android:id="@+id/tvDay14" android:layout_width="44dp" android:layout_height="44dp" android:gravity="center" android:text="14" android:textColor="#212121" android:textSize="18sp" android:textStyle="bold" android:background="@drawable/bg_day_active" />
        </LinearLayout>

        <!-- WED -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="WED" android:textColor="#9E9E9E" android:textSize="10sp" />
            <TextView android:id="@+id/tvDay15" android:layout_width="44dp" android:layout_height="44dp" android:gravity="center" android:text="15" android:textColor="#2196F3" android:textSize="18sp" android:textStyle="bold" />
        </LinearLayout>

        <!-- THU -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="THU" android:textColor="#9E9E9E" android:textSize="10sp" />
            <TextView android:id="@+id/tvDay16" android:layout_width="44dp" android:layout_height="44dp" android:gravity="center" android:text="16" android:textColor="#212121" android:textSize="18sp" android:textStyle="bold" android:background="@drawable/bg_day_inactive" />
        </LinearLayout>

        <!-- FRI -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FRI" android:textColor="#9E9E9E" android:textSize="10sp" />
            <TextView android:id="@+id/tvDay17" android:layout_width="44dp" android:layout_height="44dp" android:gravity="center" android:text="17" android:textColor="#212121" android:textSize="18sp" android:textStyle="bold" android:background="@drawable/bg_day_inactive" />
        </LinearLayout>

    </LinearLayout>

    <!-- Events Section - Live Data Only -->
    <TextView
        android:id="@+id/tvEventsHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Events"
        android:textColor="#212121"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="12dp" />

    <!-- Live Events RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDayMoments"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false" />

    <!-- Empty State -->
    <TextView
        android:id="@+id/tvNoMomentsDay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No events today"
        android:textColor="#BDBDBD"
        android:textSize="14sp"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone" />

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@drawable/ic_add"
        android:contentDescription="Add"
        app:backgroundTint="#212121"
        app:tint="#FFFFFF" />

    <!-- Hidden for compatibility -->
    <ImageButton android:id="@+id/btnPrevMonth" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <ImageButton android:id="@+id/btnNextMonth" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <ImageButton android:id="@+id/btnPrevYear" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <ImageButton android:id="@+id/btnNextYear" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <Button android:id="@+id/btnToday" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvCalendar" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvWeek" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView android:id="@+id/tvCalendarHint" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView android:id="@+id/tvSelectedDate" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView android:id="@+id/tvDayTotal" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <LinearLayout android:id="@+id/emptyState" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <com.google.android.material.card.MaterialCardView android:id="@+id/floatingNavbarContainer" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <com.google.android.material.appbar.MaterialToolbar android:id="@+id/toolbar" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <com.google.android.material.appbar.AppBarLayout android:id="@+id/appBarLayout" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <androidx.cardview.widget.CardView android:id="@+id/cardDayEvents" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvDayExpenses" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView android:id="@+id/tvNoExpensesDay" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

</LinearLayout>