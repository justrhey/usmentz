<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:background="#FFFFFF"
            android:paddingStart="8dp"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="#9B5CFF"
            app:elevation="0dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="3dp"
                    android:layout_height="24dp"
                    android:background="#9B5CFF"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Calendar"
                        android:textColor="#212121"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvCalendarHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="browse your moments"
                        android:textColor="#9E9E9E"
                        android:textSize="10sp" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.appbar.MaterialToolbar>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <!-- Calendar Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="28dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Month display -->
                    <TextView
                        android:id="@+id/tvMonth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MARCH"
                        android:textColor="#9B5CFF"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <!-- Day headers -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">

                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="S" android:textColor="#9E9E9E" android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="M" android:textColor="#9E9E9E" android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="T" android:textColor="#9E9E9E" android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="W" android:textColor="#9E9E9E" android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="T" android:textColor="#9E9E9E" android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="F" android:textColor="#9E9E9E" android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="S" android:textColor="#9E9E9E" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Calendar grid -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvCalendar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Selected date label -->
            <TextView
                android:id="@+id/tvSelectedDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="8dp"
                android:text="Events for today"
                android:textColor="#212121"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <!-- Day moments list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDayMoments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:clipToPadding="false"/>

            <!-- Month navigation buttons (hidden, for Java code) -->
            <ImageButton
                android:id="@+id/btnPrevMonth"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"/>
            <ImageButton
                android:id="@+id/btnNextMonth"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"/>
            <ImageButton
                android:id="@+id/btnPrevYear"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"/>
            <ImageButton
                android:id="@+id/btnNextYear"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"/>
            <Button
                android:id="@+id/btnToday"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Floating Pill Navbar -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/floatingNavbarContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="#F2FFFFFF"
        app:cardCornerRadius="32dp"
        app:cardElevation="8dp"
        app:strokeWidth="1dp"
        app:strokeColor="#E0E0E0">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <LinearLayout android:id="@+id/navHome" android:layout_width="64dp" android:layout_height="56dp" android:orientation="vertical" android:gravity="center" android:background="?attr/selectableItemBackgroundBorderless" android:clickable="true">
                <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_home" app:tint="#9E9E9E"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Home" android:textSize="11sp" android:textColor="#9E9E9E"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/navReviews" android:layout_width="64dp" android:layout_height="56dp" android:orientation="vertical" android:gravity="center" android:background="?attr/selectableItemBackgroundBorderless" android:clickable="true">
                <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_star" app:tint="#9E9E9E"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Reviews" android:textSize="11sp" android:textColor="#9E9E9E"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/navFavorites" android:layout_width="64dp" android:layout_height="56dp" android:orientation="vertical" android:gravity="center" android:background="?attr/selectableItemBackgroundBorderless" android:clickable="true">
                <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_favorite" app:tint="#9E9E9E"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Favorites" android:textSize="11sp" android:textColor="#9E9E9E"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/navCalendar" android:layout_width="64dp" android:layout_height="56dp" android:orientation="vertical" android:gravity="center" android:background="?attr/selectableItemBackgroundBorderless" android:clickable="true">
                <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_calendar" app:tint="#9B5CFF"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Calendar" android:textSize="11sp" android:textColor="#9B5CFF"/>
            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- FAB - at far right -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:src="@drawable/ic_add"
        android:contentDescription="Add"
        app:backgroundTint="#9B5CFF"
        app:tint="#FFFFFF"
        app:fabSize="normal"
        app:elevation="6dp"/>

    <!-- Hidden button for Java compatibility -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddCategory"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"/>

    <!-- Hidden views for Java compatibility -->
    <TextView android:id="@+id/tvYear" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView android:id="@+id/tvNoMomentsDay" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView android:id="@+id/tvNoExpensesDay" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView android:id="@+id/tvDayTotal" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <androidx.cardview.widget.CardView android:id="@+id/cardDayEvents" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvDayExpenses" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>