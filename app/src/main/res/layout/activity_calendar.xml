<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F7FF"
    android:fitsSystemWindows="true">

    <!-- ═══════════════════════════════════════════ -->
    <!-- MAIN CONTENT (Calendar fills the screen)   -->
    <!-- ═══════════════════════════════════════════ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Full-screen calendar background -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FFFFFF"/>

        <!-- Header bar: Month/Year + Sidebar handle -->
        <LinearLayout
            android:id="@+id/topHeader"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <!-- Month Year -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom">

                <TextView
                    android:id="@+id/tvMonth"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="July"
                    android:textColor="#1A1A1A"
                    android:textSize="22sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvYear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2026"
                    android:textColor="#BDBDBD"
                    android:textSize="14sp"
                    android:layout_marginStart="6dp"
                    android:layout_marginBottom="2dp"/>

            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <!-- Sidebar handle (hamburger bars) -->
            <LinearLayout
                android:id="@+id/btnOpenDrawer"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp">

                <!-- 3 horizontal bars -->
                <View
                    android:layout_width="20dp"
                    android:layout_height="2dp"
                    android:background="#9E9E9E"
                    android:layout_marginBottom="4dp"/>
                <View
                    android:layout_width="20dp"
                    android:layout_height="2dp"
                    android:background="#9E9E9E"
                    android:layout_marginBottom="4dp"/>
                <View
                    android:layout_width="20dp"
                    android:layout_height="2dp"
                    android:background="#9E9E9E"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Today pill + Prev/Next row -->
        <LinearLayout
            android:id="@+id/todayBar"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:background="#FFFFFF"
            android:elevation="2dp">

            <Button
                android:id="@+id/btnToday"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:text="Today"
                android:textColor="#9B5CFF"
                android:textSize="11sp"
                android:textAllCaps="false"
                android:paddingHorizontal="14dp"
                android:background="@drawable/bg_pill_purple"/>

            <View
                android:layout_width="16dp"
                android:layout_height="0dp"/>

            <ImageButton
                android:id="@+id/btnPrevMonth"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#9E9E9E"
                android:contentDescription="Previous month"
                android:padding="6dp"/>

            <TextView
                android:id="@+id/tvNavLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="July 2026"
                android:textColor="#1A1A1A"
                android:textSize="13sp"
                android:layout_marginHorizontal="8dp"/>

            <ImageButton
                android:id="@+id/btnNextMonth"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_back"
                android:rotation="180"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#9E9E9E"
                android:contentDescription="Next month"
                android:padding="6dp"/>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <!-- Add pill -->
            <LinearLayout
                android:id="@+id/btnAdd"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp"
                android:background="@drawable/bg_pill_add"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_add"
                    app:tint="#FFFFFF"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginStart="5dp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="96dp"
            android:background="#F0F0F0"/>

        <!-- Main calendar grid (fills remaining space) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="97dp"
            android:orientation="vertical">

            <!-- Day name headers -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:background="#FFFFFF">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="S"
                    android:textColor="#BDBDBD"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:fontFamily="sans-serif-medium"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="M"
                    android:textColor="#BDBDBD"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:fontFamily="sans-serif-medium"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="T"
                    android:textColor="#BDBDBD"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:fontFamily="sans-serif-medium"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="W"
                    android:textColor="#BDBDBD"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:fontFamily="sans-serif-medium"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="T"
                    android:textColor="#BDBDBD"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:fontFamily="sans-serif-medium"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="F"
                    android:textColor="#BDBDBD"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:fontFamily="sans-serif-medium"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="S"
                    android:textColor="#BDBDBD"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:fontFamily="sans-serif-medium"/>

            </LinearLayout>

            <!-- Grid + events below -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="4dp">

                <!-- Calendar grid -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvCalendar"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:overScrollMode="never"/>

                <!-- Day events card (below grid) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardDayEvents"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginBottom="80dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:id="@+id/tvSelectedDate"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="July 15, 2026"
                                android:textColor="#1A1A1A"
                                android:textSize="14sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/tvDayTotal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2 moments"
                                android:textColor="#9B5CFF"
                                android:textSize="11sp"/>

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#F0F0F0"
                            android:layout_marginBottom="8dp"/>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvDayMoments"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"/>

                        <TextView
                            android:id="@+id/tvNoMomentsDay"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="No moments on this day"
                            android:textColor="#BDBDBD"
                            android:textSize="13sp"
                            android:visibility="gone"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>

        <!-- FAB -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabAdd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="20dp"
            android:src="@drawable/ic_add"
            android:contentDescription="Add"
            app:backgroundTint="#9B5CFF"
            app:tint="#FFFFFF"
            app:fabSize="normal"
            app:elevation="12dp"/>

        <!-- Floating Navbar (auto-hide) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/floatingNavbarContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="#F2FFFFFF"
            app:cardCornerRadius="32dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="76dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="6dp"
                android:paddingEnd="6dp">

                <LinearLayout
                    android:id="@+id/navHome"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_home" app:tint="#9E9E9E"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Home" android:textSize="8sp" android:textColor="#9E9E9E" android:layout_marginTop="2dp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/navCategories"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_category" app:tint="#9E9E9E"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Categories" android:textSize="8sp" android:textColor="#9E9E9E" android:layout_marginTop="2dp"/>
                </LinearLayout>

                <!-- Reviews - hidden, reviews are now private diary entries -->
                <LinearLayout
                    android:id="@+id/navReviews"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_star" app:tint="#9E9E9E"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Reviews" android:textSize="8sp" android:textColor="#9E9E9E" android:layout_marginTop="2dp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/navCalendar"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_calendar" app:tint="#9B5CFF"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Calendar" android:textSize="8sp" android:textColor="#9B5CFF" android:layout_marginTop="2dp"/>
                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </FrameLayout>

    <!-- ═══════════════════════════════════════════ -->
    <!-- SIDEBAR DRAWER (slides from left)             -->
    <!-- ═══════════════════════════════════════════ -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navDrawer"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        app:headerLayout="@layout/drawer_calendar_header"
        app:menu="@menu/menu_calendar_drawer"/>

</androidx.drawerlayout.widget.DrawerLayout>