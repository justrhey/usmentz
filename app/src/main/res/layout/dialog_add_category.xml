<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="28dp"
    android:paddingBottom="24dp">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="New Category"
        android:textColor="#212121"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Organise your moments"
        android:textColor="#9E9E9E"
        android:textSize="14sp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="24dp" />

    <!-- Name field -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Category name"
        app:hintTextColor="#9E9E9E"
        app:boxStrokeColor="#9B5CFF"
        app:boxStrokeWidth="1dp"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_marginBottom="20dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etCategoryName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#212121"
            android:textSize="16sp"
            android:inputType="textCapSentences"
            android:singleLine="true" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Icon row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <ImageView
            android:id="@+id/ivIconPreview"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/folder"
            android:scaleType="centerInside"
            android:background="@drawable/bg_icon_preview"
            android:padding="8dp" />

        <TextView
            android:id="@+id/tvIconPreview"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Folder"
            android:textColor="#9B5CFF"
            android:textSize="14sp"
            android:layout_marginStart="12dp" />

        <Button
            android:id="@+id/btnIconDropdown"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Change"
            android:textColor="#9B5CFF"
            android:textSize="12sp"
            android:backgroundTint="#F3E5F5"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap Change to cycle through icons"
        android:textColor="#9E9E9E"
        android:textSize="12sp"
        android:layout_marginBottom="20dp" />

    <!-- Color picker - beautiful gradient circles -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="COLOR"
        android:textColor="#9E9E9E"
        android:textSize="12sp"
        android:layout_marginBottom="12dp" />

    <!-- Color circles row with gradients -->
    <LinearLayout
        android:id="@+id/colorPickerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="24dp">

        <!-- Purple -->
        <View
            android:id="@+id/colorPurple"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_gradient_purple"
            android:tag="#9B5CFF"/>

        <!-- Red -->
        <View
            android:id="@+id/colorRed"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_gradient_red"
            android:tag="#FF5252"/>

        <!-- Blue -->
        <View
            android:id="@+id/colorBlue"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_gradient_blue"
            android:tag="#2196F3"/>

        <!-- Green -->
        <View
            android:id="@+id/colorGreen"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_gradient_green"
            android:tag="#4CAF50"/>

        <!-- Orange -->
        <View
            android:id="@+id/colorOrange"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_gradient_orange"
            android:tag="#FF9800"/>

        <!-- Pink -->
        <View
            android:id="@+id/colorPink"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_gradient_pink"
            android:tag="#E91E63"/>

    </LinearLayout>

    <!-- Hidden spinner still for Java compatibility -->
    <Spinner
        android:id="@+id/spinnerColor"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="Cancel"
            android:textColor="#757575"
            android:textSize="14sp"
            android:backgroundTint="#F5F5F5"
            android:layout_marginEnd="8dp"
            app:cornerRadius="12dp" />

        <Button
            android:id="@+id/btnCreate"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="Create"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:backgroundTint="#9B5CFF"
            app:cornerRadius="12dp" />

    </LinearLayout>

</LinearLayout>