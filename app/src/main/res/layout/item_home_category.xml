<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="150dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="10dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF"
    app:strokeWidth="0dp"
    app:rippleColor="#209B5CFF"
    android:clickable="true"
    android:focusable="true">

    <!-- Colored top strip -->
    <View
        android:id="@+id/topStrip"
        android:layout_width="match_parent"
        android:layout_height="5dp"
        android:background="#9B5CFF" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp"
        android:layout_marginTop="6dp">

        <!-- Category Icon Circle with gradient -->
        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginBottom="10dp">

            <View
                android:id="@+id/viewIconBg"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_gradient_purple" />

            <ImageView
                android:id="@+id/ivIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/folder"
                android:scaleType="centerInside" />

        </FrameLayout>

        <!-- Category Name -->
        <TextView
            android:id="@+id/tvCategoryName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#2D2640"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginBottom="2dp" />

        <!-- Item Count -->
        <TextView
            android:id="@+id/tvItemCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#8B7FA8"
            android:textSize="11sp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>