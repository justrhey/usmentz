<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_pure">

    <!-- Static Background Branding (visible behind the sheet) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="32dp">

        <!-- Character/Mascot placeholder -->
        <View
            android:id="@+id/ivMascot"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:background="@drawable/bg_mascot_circle"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="usmentz"
            android:textColor="@color/purple_primary"
            android:textSize="36sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_marginTop="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Track moments together"
            android:textColor="@color/text_hint"
            android:textSize="15sp"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

    <!-- Sliding Bottom Sheet Card -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/slideCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_hideable="false"
        app:behavior_peekHeight="160dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_bottom_sheet"
            android:paddingHorizontal="28dp"
            android:paddingTop="14dp"
            android:paddingBottom="40dp">

            <!-- Wider Drag Handle -->
            <View
                android:layout_width="56dp"
                android:layout_height="5dp"
                android:background="@drawable/bg_handle"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp"/>

            <!-- Welcome Text -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Welcome Back"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sign in to continue"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginBottom="18dp"/>

            <!-- Email Field -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Email"
                app:boxStrokeColor="@color/purple_primary"
                app:boxStrokeWidth="1dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="10dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:inputType="textEmailAddress"
                    android:singleLine="true"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password Field -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Password"
                app:endIconMode="password_toggle"
                app:boxStrokeColor="@color/purple_primary"
                app:boxStrokeWidth="1dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="6dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:inputType="textPassword"
                    android:singleLine="true"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Forgot Password -->
            <TextView
                android:id="@+id/tvForgotPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Forgot password?"
                android:textColor="@color/purple_primary"
                android:textSize="12sp"
                android:layout_gravity="end"
                android:paddingVertical="4dp"
                android:layout_marginBottom="14dp"/>

            <!-- Log In Button -->
            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Log In"
                android:textColor="@color/black_pure"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="@color/purple_primary"
                app:cornerRadius="25dp"
                android:layout_marginBottom="14dp"/>

            <!-- OR Divider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="12dp">

                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="@color/gray_dark"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="or" android:textColor="@color/text_hint" android:textSize="12sp" android:paddingHorizontal="12dp"/>
                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="@color/gray_dark"/>

            </LinearLayout>

            <!-- Google Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoogle"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Continue with Google"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                app:icon="@drawable/ic_google"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:backgroundTint="@color/black_elevated"
                app:strokeColor="@color/gray_dark"
                app:strokeWidth="1dp"
                app:cornerRadius="25dp"
                android:layout_marginBottom="14dp"/>

            <!-- Sign Up Link -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Don't have an account? "
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/tvSignUp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign Up"
                    android:textColor="@color/purple_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:indeterminateTint="@color/purple_primary"
        android:layout_gravity="center"/>

    <!-- Error -->
    <TextView
        android:id="@+id/tvError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/accent_red"
        android:textSize="13sp"
        android:gravity="center"
        android:visibility="gone"
        android:paddingHorizontal="32dp"
        android:layout_gravity="center"
        android:layout_marginBottom="80dp"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
