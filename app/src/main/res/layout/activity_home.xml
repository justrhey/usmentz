<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_pure">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingBottom="120dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="48dp"
                android:paddingBottom="16dp">

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GOOD MORNING"
                    android:textSize="11sp"
                    android:textColor="@color/purple_primary"
                    android:letterSpacing="0.08"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your moments"
                    android:textSize="24sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thursday, May 21"
                    android:textSize="13sp"
                    android:textColor="@color/text_hint"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <!-- Streak Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/streakCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="18dp"
                app:cardBackgroundColor="@color/black_elevated"
                app:cardElevation="0dp"
                app:strokeColor="@color/black_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CURRENT STREAK"
                                android:textSize="11sp"
                                android:textColor="@color/purple_primary"
                                android:textStyle="bold"
                                android:letterSpacing="0.06" />

                            <TextView
                                android:id="@+id/tvStreakCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="44sp"
                                android:textColor="@color/purple_glow"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="days tracking"
                                android:textSize="12sp"
                                android:textColor="@color/text_hint" />

                        </LinearLayout>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:cardCornerRadius="12dp"
                            app:cardBackgroundColor="@color/purple_surface"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="12dp">

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@drawable/ic_flame"
                                    app:tint="@color/purple_glow" />

                                <TextView
                                    android:id="@+id/tvBestStreak"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Best: 0"
                                    android:textSize="10sp"
                                    android:textColor="@color/purple_primary"
                                    android:layout_marginTop="4dp" />

                            </LinearLayout>

                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                    <!-- Weekday dots -->
                    <LinearLayout
                        android:id="@+id/weekDots"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="14dp">

                        <TextView android:id="@+id/dotMon" android:layout_width="0dp" android:layout_height="28dp" android:layout_weight="1" android:text="M" android:gravity="center" android:textSize="10sp" android:textColor="@color/text_hint" android:background="@drawable/bg_streak_dot_empty" />
                        <View android:layout_width="4dp" android:layout_height="1dp" />
                        <TextView android:id="@+id/dotTue" android:layout_width="0dp" android:layout_height="28dp" android:layout_weight="1" android:text="T" android:gravity="center" android:textSize="10sp" android:textColor="@color/text_hint" android:background="@drawable/bg_streak_dot_empty" />
                        <View android:layout_width="4dp" android:layout_height="1dp" />
                        <TextView android:id="@+id/dotWed" android:layout_width="0dp" android:layout_height="28dp" android:layout_weight="1" android:text="W" android:gravity="center" android:textSize="10sp" android:textColor="@color/text_hint" android:background="@drawable/bg_streak_dot_empty" />
                        <View android:layout_width="4dp" android:layout_height="1dp" />
                        <TextView android:id="@+id/dotThu" android:layout_width="0dp" android:layout_height="28dp" android:layout_weight="1" android:text="T" android:gravity="center" android:textSize="10sp" android:textColor="@color/text_hint" android:background="@drawable/bg_streak_dot_empty" />
                        <View android:layout_width="4dp" android:layout_height="1dp" />
                        <TextView android:id="@+id/dotFri" android:layout_width="0dp" android:layout_height="28dp" android:layout_weight="1" android:text="F" android:gravity="center" android:textSize="10sp" android:textColor="@color/text_hint" android:background="@drawable/bg_streak_dot_empty" />
                        <View android:layout_width="4dp" android:layout_height="1dp" />
                        <TextView android:id="@+id/dotSat" android:layout_width="0dp" android:layout_height="28dp" android:layout_weight="1" android:text="S" android:gravity="center" android:textSize="10sp" android:textColor="@color/text_hint" android:background="@drawable/bg_streak_dot_empty" />
                        <View android:layout_width="4dp" android:layout_height="1dp" />
                        <TextView android:id="@+id/dotSun" android:layout_width="0dp" android:layout_height="28dp" android:layout_weight="1" android:text="S" android:gravity="center" android:textSize="10sp" android:textColor="@color/text_hint" android:background="@drawable/bg_streak_dot_empty" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Quick Actions Row (D) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick capture"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:id="@+id/quickActionsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="20dp"
                android:weightSum="4">

                <LinearLayout
                    android:id="@+id/actionPhoto"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true">
                    <ImageView android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_camera" android:background="@drawable/bg_icon_orange" android:padding="12dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Photo" android:textSize="11sp" android:textColor="@color/text_hint" android:layout_marginTop="6dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/actionNote"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true">
                    <ImageView android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_note" android:background="@drawable/bg_icon_purple" android:padding="12dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Note" android:textSize="11sp" android:textColor="@color/text_hint" android:layout_marginTop="6dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/actionVoice"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true">
                    <ImageView android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_comment" android:background="@drawable/bg_icon_teal" android:padding="12dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Voice" android:textSize="11sp" android:textColor="@color/text_hint" android:layout_marginTop="6dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/actionLocation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true">
                    <ImageView android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_location" android:background="@drawable/bg_icon_pink" android:padding="12dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Place" android:textSize="11sp" android:textColor="@color/text_hint" android:layout_marginTop="6dp" />
                </LinearLayout>

            </LinearLayout>

            <!-- Top Categories Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Top categories"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSeeAllCategories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="See all"
                    android:textSize="13sp"
                    android:textColor="@color/purple_primary" />

            </LinearLayout>

            <!-- Categories Grid -->
            <GridLayout
                android:id="@+id/categoriesGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="20dp"
                android:columnCount="2"
                android:useDefaultMargins="false">

                <!-- Card 1 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/catCard1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="5dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/black_elevated"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/black_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            app:cardCornerRadius="12dp"
                            app:cardBackgroundColor="#FFF3E0"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">
                            <ImageView
                                android:id="@+id/catIcon1"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_heart_outline"
                                android:padding="4dp" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/catLabel1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Category"
                            android:textSize="11sp"
                            android:textColor="@color/text_hint"
                            android:layout_marginTop="10dp" />

                        <TextView
                            android:id="@+id/catCount1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="22sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/catSub1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="moments"
                            android:textSize="10sp"
                            android:textColor="@color/text_disabled" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Card 2 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/catCard2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="5dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/black_card"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/black_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            app:cardCornerRadius="12dp"
                            app:cardBackgroundColor="#F3E5F5"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">
                            <ImageView
                                android:id="@+id/catIcon2"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_calendar_outline"
                                android:padding="4dp" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/catLabel2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Category"
                            android:textSize="11sp"
                            android:textColor="@color/text_hint"
                            android:layout_marginTop="10dp" />

                        <TextView
                            android:id="@+id/catCount2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="22sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/catSub2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="moments"
                            android:textSize="10sp"
                            android:textColor="@color/text_disabled" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Card 3 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/catCard3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="5dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/black_card"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/black_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            app:cardCornerRadius="12dp"
                            app:cardBackgroundColor="#E0F2F1"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">
                            <ImageView
                                android:id="@+id/catIcon3"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_folder_outline"
                                android:padding="4dp" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/catLabel3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Category"
                            android:textSize="11sp"
                            android:textColor="@color/text_hint"
                            android:layout_marginTop="10dp" />

                        <TextView
                            android:id="@+id/catCount3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="22sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/catSub3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="moments"
                            android:textSize="10sp"
                            android:textColor="@color/text_disabled" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Card 4 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/catCard4"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="5dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/black_card"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/black_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            app:cardCornerRadius="12dp"
                            app:cardBackgroundColor="#FCE4EC"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">
                            <ImageView
                                android:id="@+id/catIcon4"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_info_outline"
                                android:padding="4dp" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/catLabel4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Category"
                            android:textSize="11sp"
                            android:textColor="@color/text_hint"
                            android:layout_marginTop="10dp" />

                        <TextView
                            android:id="@+id/catCount4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="22sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/catSub4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="moments"
                            android:textSize="10sp"
                            android:textColor="@color/text_disabled" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <!-- Recent Moments Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Recent moments"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSeeAllMoments"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="See all"
                    android:textSize="13sp"
                    android:textColor="@color/purple_primary" />

            </LinearLayout>

            <!-- Recent Moments List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecentActivity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:nestedScrollingEnabled="false"/>

            <!-- Loading State -->
            <ProgressBar
                android:id="@+id/progressLoading"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="100dp"
                android:indeterminateTint="@color/purple_primary"
                android:visibility="gone" />

            <!-- Empty State -->
            <LinearLayout
                android:id="@+id/emptyStateHome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="60dp"
                android:paddingBottom="60dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:src="@drawable/ic_camera_large"
                    android:alpha="0.3"
                    app:tint="@color/text_hint" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Start your story"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="20dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap + to capture your first moment"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRefreshHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Refresh"
                    android:textSize="12sp"
                    android:layout_marginTop="16dp"
                    app:cornerRadius="20dp"
                    android:backgroundTint="@color/purple_primary"
                    android:textColor="@color/black_pure" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- UNIVERSAL CAPSULE NAVBAR -->
    <include 
        android:id="@+id/capsuleNavbar"
        layout="@layout/bottom_nav_capsule"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom" />

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="100dp"
        android:src="@drawable/ic_add"
        android:contentDescription="Add"
        app:backgroundTint="@color/purple_primary"
        app:tint="@color/black_pure"
        app:fabSize="normal"
        app:elevation="12dp"
        app:pressedTranslationZ="8dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
