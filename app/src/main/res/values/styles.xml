<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base Application Theme -->
    <style name="Theme.Usmentz" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary colors -->
        <item name="colorPrimary">@color/purple_primary</item>
        <item name="colorPrimaryVariant">@color/purple_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary colors -->
        <item name="colorSecondary">@color/teal_accent</item>
        <item name="colorSecondaryVariant">@color/teal_dim</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Background colors -->
        <item name="android:colorBackground">@color/black_pure</item>
        <item name="colorSurface">@color/dark_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/dark_elevated</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <!-- Error colors -->
        <item name="colorError">@color/accent_red</item>
        <item name="colorOnError">@color/white</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/black_pure</item>
        <item name="android:navigationBarColor">@color/black_pure</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Text appearance -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>

        <!-- Smooth animations -->
        <item name="android:windowAnimationStyle">@style/WindowAnimationTransition</item>
        <item name="android:windowContentTransitions">true</item>

        <!-- Default shape appearances - CURVED -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.Usmentz.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.Usmentz.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.Usmentz.Large</item>
    </style>

    <!-- Shape Appearances - All Curves -->
    <style name="ShapeAppearance.Usmentz.Small" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearance.Usmentz.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <style name="ShapeAppearance.Usmentz.Large" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">32dp</item>
    </style>

    <!-- Material3 Theme Overrides -->
    <style name="ThemeOverlay.Material3.Button.IconButton" parent="">
    </style>

    <style name="ThemeOverlay.Material3.Button.TextButton" parent="">
    </style>

    <!-- Alert Dialog Theme -->
    <style name="AlertDialogTheme" parent="ThemeOverlay.Material3.Dialog.Alert">
        <item name="android:background">@color/dark_surface</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="buttonBarPositiveButtonStyle">@style/PositiveButtonStyle</item>
        <item name="buttonBarNegativeButtonStyle">@style/NegativeButtonStyle</item>
    </style>

    <style name="PositiveButtonStyle" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/purple_primary</item>
    </style>

    <style name="NegativeButtonStyle" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- Calendar day header -->
    <style name="CalDayHeader">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#808080</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- No ActionBar Theme for Login/Register -->
    <style name="Theme.Usmentz.NoActionBar" parent="Theme.Usmentz">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:statusBarColor">#F8F7FF</item>
        <item name="android:navigationBarColor">#F8F7FF</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowBackground">#F8F7FF</item>
        <item name="android:windowActivityTransitions">true</item>
        <item name="android:windowAnimationStyle">@style/WindowAnimationTransition</item>
    </style>

    <!-- Splash Theme -->
    <style name="Theme.Usmentz.Splash" parent="Theme.Usmentz">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:statusBarColor">@color/black_pure</item>
        <item name="android:navigationBarColor">@color/black_pure</item>
    </style>

    <!-- Window Animation Transition -->
    <style name="WindowAnimationTransition">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
    </style>

    <!-- Card Style - CURVED -->
    <style name="ModernCard" parent="">
        <item name="cardBackgroundColor">@color/dark_card</item>
        <item name="cardCornerRadius">28dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <!-- Button Style - CURVED -->
    <style name="ModernButton" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/purple_primary</item>
        <item name="cornerRadius">28dp</item>
    </style>

    <!-- Outlined Button Style - CURVED -->
    <style name="OutlinedButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/purple_primary</item>
        <item name="strokeColor">@color/purple_primary</item>
        <item name="strokeWidth">2dp</item>
        <item name="cornerRadius">28dp</item>
    </style>

    <!-- FAB Style -->
    <style name="ModernFAB" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/purple_primary</item>
        <item name="tint">@color/white</item>
    </style>

    <style name="ShapeAppearance.Usmentz.TopCorners" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">40dp</item>
        <item name="cornerSizeTopRight">40dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!-- Bottom Sheet Dialog Theme -->
    <style name="BottomSheetDialog" parent="Theme.MaterialComponents.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/BottomSheetStyle</item>
    </style>

    <style name="BottomSheetStyle" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="shapeAppearance">@style/ShapeAppearance.Usmentz.BottomSheet</item>
        <item name="backgroundTint">@color/white</item>
    </style>

    <style name="ShapeAppearance.Usmentz.BottomSheet" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!-- Circle Image View Style -->
    <style name="CircleImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- Rounded Corners 16dp for photo preview -->
    <style name="RoundedCorners16" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

</resources>