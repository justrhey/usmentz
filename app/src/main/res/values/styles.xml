<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base Application Theme - Simple Dark -->
    <style name="Theme.Usmentz" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary colors -->
        <item name="colorPrimary">@color/purple_primary</item>
        <item name="colorPrimaryVariant">@color/purple_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary colors -->
        <item name="colorSecondary">@color/teal_accent</item>
        <item name="colorSecondaryVariant">@color/teal_dim</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Background colors -->
        <item name="android:colorBackground">@color/black_pure</item>
        <item name="colorSurface">@color/dark_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/dark_elevated</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <!-- Error colors -->
        <item name="colorError">@color/accent_red</item>
        <item name="colorOnError">@color/white</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/black_pure</item>
        <item name="android:navigationBarColor">@color/black_pure</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Text appearance -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>

        <!-- NO animations - instant transitions -->
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowContentTransitions">false</item>
    </style>

    <!-- Material3 Theme Overrides -->
    <style name="ThemeOverlay.Material3.Button.IconButton" parent="">
    </style>

    <style name="ThemeOverlay.Material3.Button.TextButton" parent="">
    </style>

    <!-- Alert Dialog Theme -->
    <style name="AlertDialogTheme" parent="ThemeOverlay.Material3.Dialog.Alert">
        <item name="android:background">@color/dark_surface</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="buttonBarPositiveButtonStyle">@style/PositiveButtonStyle</item>
        <item name="buttonBarNegativeButtonStyle">@style/NegativeButtonStyle</item>
    </style>

    <style name="PositiveButtonStyle" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/purple_primary</item>
    </style>

    <style name="NegativeButtonStyle" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- Calendar day header -->
    <style name="CalDayHeader">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#808080</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Splash Theme -->
    <style name="Theme.Usmentz.Splash" parent="Theme.Usmentz">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:statusBarColor">@color/black_pure</item>
        <item name="android:navigationBarColor">@color/black_pure</item>
    </style>

    <!-- Card Style -->
    <style name="ModernCard" parent="">
        <item name="cardBackgroundColor">@color/dark_card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
    </style>

    <!-- Button Style -->
    <style name="ModernButton" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/purple_primary</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- FAB Style -->
    <style name="ModernFAB" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/purple_primary</item>
        <item name="tint">@color/white</item>
    </style>

</resources>